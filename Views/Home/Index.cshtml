                                Preview Template <i data-lucide="external-link" class="w-4 h-4"></i>
                            </a>
                         </div>
                    </div>
                    <div class="p-6 border-t border-gray-200/50 dark:border-white/5 bg-white/50 dark:bg-black/20">
                        <h4 class="text-xl font-bold mb-1">Minimalist Developer</h4>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Clean, focus-driven design for backend engineers.</p>
                    </div>
                </div>

                <!-- Portfolio 2 -->
                <div class="group relative rounded-3xl overflow-hidden glass border border-gray-200/50 dark:border-white/5 hover:border-brand-500/50 transition-all duration-500 reveal delay-100">
                    <div class="aspect-video w-full bg-gray-100 dark:bg-gray-900 overflow-hidden relative">
                         <iframe src="/Templates/Portfolio2.html" class="w-[400%] h-[400%] absolute top-0 left-0 transform scale-[0.25] origin-top-left border-0 pointer-events-none" loading="lazy"></iframe>
                         <div class="absolute inset-0 bg-gray-900/0 group-hover:bg-gray-900/40 transition-all duration-300 z-10 flex items-center justify-center backdrop-blur-[0px] group-hover:backdrop-blur-sm">
                            <a href="/Templates/Portfolio2.html" target="_blank" class="transform translate-y-10 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 bg-white dark:bg-black text-black dark:text-white px-8 py-3 rounded-full font-bold flex items-center gap-2 shadow-2xl hover:scale-105">
                                Preview Template <i data-lucide="external-link" class="w-4 h-4"></i>
                            </a>
                         </div>
                    </div>
                    <div class="p-6 border-t border-gray-200/50 dark:border-white/5 bg-white/50 dark:bg-black/20">
                        <h4 class="text-xl font-bold mb-1">Creative Studio</h4>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Vibrant and expressive for frontend wizards.</p>
                    </div>
                </div>

                <!-- Portfolio 3 -->
                <div class="group relative rounded-3xl overflow-hidden glass border border-gray-200/50 dark:border-white/5 hover:border-brand-500/50 transition-all duration-500 reveal delay-200">
                    <div class="aspect-video w-full bg-gray-100 dark:bg-gray-900 overflow-hidden relative">
                         <iframe src="/Templates/Portfolio3.html" class="w-[400%] h-[400%] absolute top-0 left-0 transform scale-[0.25] origin-top-left border-0 pointer-events-none" loading="lazy"></iframe>
                         <div class="absolute inset-0 bg-gray-900/0 group-hover:bg-gray-900/40 transition-all duration-300 z-10 flex items-center justify-center backdrop-blur-[0px] group-hover:backdrop-blur-sm">
                            <a href="/Templates/Portfolio3.html" target="_blank" class="transform translate-y-10 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 bg-white dark:bg-black text-black dark:text-white px-8 py-3 rounded-full font-bold flex items-center gap-2 shadow-2xl hover:scale-105">
                                Preview Template <i data-lucide="external-link" class="w-4 h-4"></i>
                            </a>
                         </div>
                    </div>
                    <div class="p-6 border-t border-gray-200/50 dark:border-white/5 bg-white/50 dark:bg-black/20">
