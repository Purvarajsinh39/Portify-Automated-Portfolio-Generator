                <h2 class="text-xs uppercase tracking-[0.4em] text-brand-500 font-bold mb-4">Templates</h2>
                <h3 class="text-4xl md:text-5xl font-serif italic mb-6">Choose Your Canvas</h3>
                <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
                    Select a masterpiece to showcase your work. Each template is crafted for maximum impact.
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Portfolio 1 -->
                <div class="group relative rounded-3xl overflow-hidden glass border border-gray-200/50 dark:border-white/5 hover:border-brand-500/50 transition-all duration-500 reveal">
