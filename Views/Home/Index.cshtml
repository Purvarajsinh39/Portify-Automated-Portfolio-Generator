                <!-- Coming Soon -->
                <div class="group relative rounded-3xl overflow-hidden glass border border-dashed border-gray-300 dark:border-gray-700 hover:border-brand-500/50 transition-all duration-500 reveal delay-200 flex flex-col">
                    <div class="aspect-video w-full flex items-center justify-center bg-gray-50 dark:bg-white/5">
                        <div class="text-center p-6">
                            <div class="w-20 h-20 rounded-full bg-gray-200 dark:bg-white/10 flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
                                <i data-lucide="plus" class="w-8 h-8 text-gray-400 dark:text-gray-500"></i>
                            </div>
                            <h4 class="text-xl font-bold mb-2 text-gray-400 dark:text-gray-500">More Coming Soon</h4>
                            <p class="text-sm text-gray-400 dark:text-gray-600">We are crafting new experiences.</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section id="workflow" class="py-24 px-6 relative overflow-hidden">
        <div class="max-w-7xl mx-auto flex flex-col items-center">
            <div class="max-w-3xl w-full">
                <div class="text-center mb-16 reveal">
                    <h2 class="text-3xl font-serif italic mb-4">How it Works</h2>
                    <div class="w-20 h-1 bg-brand-500 mx-auto rounded-full"></div>
                </div>

                <div class="space-y-12">
                    <div class="flex gap-6 reveal group">
                        <div class="flex-shrink-0 w-12 h-12 rounded-full border border-brand-500 flex items-center justify-center font-bold text-brand-500 group-hover:bg-brand-500 group-hover:text-white transition-all">01</div>
                        <div>
                            <h4 class="text-xl font-bold mb-2 uppercase tracking-wide">Administrator Setup</h4>
                            <p class="text-gray-500 dark:text-gray-400">Our admins upload premium templates and manage platform statistics to ensure top-tier variety and performance.</p>
                        </div>
