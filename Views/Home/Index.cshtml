                            <a href="/Templates/Portfolio5.html" target="_blank" class="transform translate-y-10 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 bg-white dark:bg-black text-black dark:text-white px-8 py-3 rounded-full font-bold flex items-center gap-2 shadow-2xl hover:scale-105">
