@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Portify</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500&display=swap" rel="stylesheet">
    <script>
        (function () {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'], serif: ['Playfair Display', 'serif'] },
                    colors: { brand: { 500: '#a855f7', 900: '#581c87' } }
                }
            }
        }
    </script>
</head>
    <style>
        @@media (max-width: 768px) {
            body { 
                overflow-y: auto !important; 
                height: auto; 
                min-height: 100vh;
                display: block !important;
                padding: 24px;
            }
            #forgot-card {
                margin-top: 48px;
                border-radius: 24px;
                padding: 32px;
                background: #0a0a0a;
                border: 1px solid rgba(255,255,255,0.05);
            }
            .mobile-header { display: block !important; }
        }
        .mobile-header { display: none; }
    </style>
</head>
<body class="bg-[#050505] text-white overflow-hidden h-screen w-screen selection:bg-brand-500 selection:text-white flex items-center justify-center">
    @Html.Partial("~/Views/Shared/_PageTransitions.cshtml")

    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 w-[800px] h-[800px] bg-brand-900/10 rounded-full blur-[150px] -translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <!-- MOBILE BRANDING -->
    <div class="mobile-header w-full text-center mb-12">
        <h1 class="text-5xl font-serif italic text-white mb-3">Portify</h1>
        <div class="h-1 w-12 bg-brand-500 mx-auto rounded-full"></div>
    </div>

    <div id="forgot-card" class="relative z-10 bg-[#171717] border border-white/10 p-10 rounded-2xl w-full max-w-md shadow-2xl transition-all">
        <div class="text-center mb-10">
            <h2 class="text-4xl font-serif italic text-white mb-3">Reset Password</h2>
            <p class="text-gray-500 text-[10px] uppercase tracking-[0.2em] leading-relaxed">
                Enter your email address to receive<br>
                a verification <span class="text-brand-500 font-bold">otp code</span>.
            </p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-500/10 border border-red-500/50 text-red-500 px-4 py-3 rounded-xl mb-6 text-sm text-center">
                @ViewBag.Error
            </div>
        }
        @if (ViewBag.Message != null)
        {
            <div class="bg-green-500/10 border border-green-500/50 text-green-500 px-4 py-3 rounded-xl mb-6 text-sm text-center">
                @ViewBag.Message
            </div>
        }

        <form action="@Url.Action("ForgotPassword", "Home")" method="post" class="space-y-6">
            <div class="space-y-2 text-left">
                <label class="text-xs uppercase font-bold text-gray-500 tracking-widest pl-1">Email Address</label>
                <input type="email" name="Email" required 
                    class="w-full bg-[#111] border border-white/5 rounded-xl py-5 px-5 text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-800"
                    placeholder="your@email.com">
            </div>

            <button type="submit" 
                class="w-full bg-brand-500 hover:bg-brand-900 text-white font-bold py-5 rounded-xl mt-4 transition-all shadow-[0_8px_30px_rgba(168,85,247,0.3)] active:scale-[0.98]">
                Send Recovery Code
            </button>
        </form>

        <div class="mt-10 pt-8 border-t border-white/5 flex justify-center">
            <a href="@Url.Action("Login", "Home")" class="flex items-center text-xs text-gray-500 hover:text-brand-500 transition-colors group">
                <i data-lucide="arrow-left" class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform"></i> Return to Sign In
            </a>
        </div>
    </div>
    
    <script>lucide.createIcons();</script>
</body>
</html>
