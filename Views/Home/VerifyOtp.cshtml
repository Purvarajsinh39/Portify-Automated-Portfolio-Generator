@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP - Portify</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'], serif: ['Playfair Display', 'serif'] },
                    colors: { brand: { 500: '#a855f7', 900: '#581c87' } }
                }
            }
        }
    </script>
</head>
<body class="bg-[#050505] text-white overflow-hidden h-screen w-screen selection:bg-brand-500 selection:text-white flex items-center justify-center">

    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 w-[800px] h-[800px] bg-brand-900/10 rounded-full blur-[150px] -translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <div class="relative z-10 bg-[#171717] border border-white/10 p-10 rounded-2xl w-full max-w-md shadow-2xl">
        <div class="text-center mb-6">
            <h2 class="text-3xl font-serif italic text-white mb-2">Verification</h2>
            <p class="text-gray-400 text-xs uppercase tracking-widest leading-relaxed">
                Enter the 6-digit code sent to<br>
                <span class="text-brand-500 font-bold lowercase">@ViewBag.Email</span>
            </p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-500/10 border border-red-500/50 text-red-500 px-4 py-3 rounded-lg mb-6 text-sm text-center">
                <i data-lucide="alert-circle" class="w-4 h-4 inline-block mr-1 -mt-0.5"></i> @ViewBag.Error
            </div>
        }
        @if (ViewBag.Message != null)
        {
            <div class="bg-green-500/10 border border-green-500/50 text-green-500 px-4 py-3 rounded-lg mb-6 text-sm text-center">
                <i data-lucide="check-circle" class="w-4 h-4 inline-block mr-1 -mt-0.5"></i> @ViewBag.Message
            </div>
        }

        <form action="@Url.Action("VerifyOtp", "Home")" method="post" class="space-y-6">
            <input type="hidden" name="email" value="@ViewBag.Email" />
            <input type="hidden" name="purpose" value="@ViewBag.Purpose" />

            <div class="space-y-2">
                <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">6-Digit Code</label>
                <input type="text" name="code" required maxlength="6" pattern="\d{6}" autocomplete="one-time-code"
                    class="w-full bg-[#0a0a0a] border border-white/10 rounded-lg py-4 px-4 text-white text-center text-2xl tracking-[0.5em] focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-800"
                    placeholder="------">
            </div>

            <button type="submit" 
                class="w-full bg-brand-500 hover:bg-brand-900 text-white font-bold py-4 rounded-lg mt-4 transition-all shadow-[0_4px_20px_rgba(168,85,247,0.4)]">
                Verify Account
            </button>
        </form>

        <form action="@Url.Action("ResendOtp", "Home")" method="post" class="mt-6 text-center">
            <input type="hidden" name="email" value="@ViewBag.Email" />
            <input type="hidden" name="purpose" value="@ViewBag.Purpose" />
            <p class="text-xs text-gray-500 mb-2">Didn't receive the code?</p>
            <button type="submit" class="text-sm text-brand-500 hover:text-white transition-colors underline underline-offset-4 decoration-white/20 hover:decoration-brand-500">
                Resend OTP
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-white/10 flex justify-center">
            <a href="@Url.Action("Login", "Home")" class="flex items-center text-xs text-gray-500 hover:text-white transition-colors group">
                <i data-lucide="arrow-left" class="w-3 h-3 mr-2 group-hover:-translate-x-1 transition-transform"></i> Back to Login
            </a>
        </div>
    </div>
    
    <script>lucide.createIcons();</script>
</body>
</html>
