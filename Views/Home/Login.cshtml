@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Seamless Gallery with Login</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500&display=swap" rel="stylesheet">

    <script>
        (function () {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif']
                    },
                    colors: {
                        brand: {
                            500: '#a855f7',
                            900: '#581c87'
                        }
                    }
                }
            }
        }
    </script>

    <style>
        /* --- SLIDER STYLES (UNCHANGED) --- */
        .slide-card {
            transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
            will-change: transform, opacity, filter;
        }

        @@keyframes progress {
            from { width: 0%; }
            to { width: 100%; }
        }

        .progress-bar {
            height: 100%;
            background: #a855f7;
            width: 0%;
        }

        .active-progress .progress-bar {
            animation-name: progress;
            animation-timing-function: linear;
        }

        .noise-bg {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        }

        /* --- NEW LOGIN STYLES --- */
        /* Modal Transitions */
        #login-modal {
            transition: opacity 0.5s ease, transform 0.5s ease;
        }
        .modal-hidden {
            opacity: 0;
            pointer-events: none;
            transform: scale(0.95);
        }
        .modal-visible {
            opacity: 1;
            pointer-events: auto;
            transform: scale(1);
        }

        /* Background Blur Transition */
        #main-view {
            transition: filter 0.5s ease;
        }
        .blur-active {
            filter: blur(16px) brightness(0.5);
        }

        /* Button Popup Animation */
        #login-trigger {
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .group:hover #login-trigger {
            opacity: 1;
            transform: translateY(0);
        }
        /* Default state: hidden and slightly down */
        #login-trigger {
            opacity: 0;
            transform: translateY(20px);
        }

        /* Input Styling */
        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active{
            -webkit-box-shadow: 0 0 0 30px #171717 inset !important;
            -webkit-text-fill-color: white !important;
        }
    </style>
</head>

<body class="bg-[#050505] text-white overflow-hidden h-screen w-screen selection:bg-brand-500 selection:text-white">
    @Html.Partial("~/Views/Shared/_PageTransitions.cshtml")

    <div id="main-view" class="group relative w-full h-full transition-all duration-500">
        
        <div class="absolute inset-0 z-0">
            <div class="absolute top-1/2 left-1/2 w-[900px] h-[900px] bg-brand-900/20 rounded-full blur-[160px] -translate-x-1/2 -translate-y-1/2"></div>
            <div class="absolute inset-0 noise-bg opacity-20 pointer-events-none"></div>
        </div>

        <div class="relative z-10 w-full h-full flex items-center justify-center">

            <div id="slider-container" class="relative w-full max-w-4xl aspect-[1920/928]"></div>

            <div id="indicators-container" class="absolute left-10 top-1/2 -translate-y-1/2 flex flex-col gap-6"></div>

        </div>

        <div class="absolute bottom-12 left-0 w-full flex justify-center z-40 pointer-events-none">
            <button id="login-trigger" onclick="openLogin()" class="pointer-events-auto bg-white text-black px-8 py-4 rounded-full font-bold uppercase tracking-widest shadow-[0_0_40px_rgba(255,255,255,0.3)] hover:bg-brand-500 hover:text-white hover:shadow-[0_0_60px_rgba(168,85,247,0.6)] flex items-center gap-3">
                <span>Login Access</span>
                <i data-lucide="lock" class="w-4 h-4"></i>
            </button>
        </div>
    </div>

    <div id="login-modal" class="fixed inset-0 z-50 flex items-center justify-center modal-hidden backdrop-blur-sm bg-black/20">
        <div class="absolute inset-0" onclick="closeLogin()"></div>
        
        <div class="relative bg-[#171717] border border-white/10 p-10 rounded-2xl w-full max-w-md shadow-2xl transform transition-all">
            
            <button onclick="closeLogin()" class="absolute top-4 right-4 text-gray-500 hover:text-white">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>

            <div class="text-center mb-8">
                <h2 id="form-title" class="text-4xl font-serif italic text-white mb-2">Welcome Back</h2>
                <p id="form-subtitle" class="text-gray-400 text-xs uppercase tracking-widest">Enter your credentials</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="bg-red-500/10 border border-red-500/50 text-red-500 px-4 py-2 rounded mb-4 text-sm text-center">
                    @ViewBag.Error
                </div>
            }
            @if (ViewBag.Message != null)
            {
                <div class="bg-green-500/10 border border-green-500/50 text-green-500 px-4 py-2 rounded mb-4 text-sm text-center">
                    @ViewBag.Message
                </div>
            }

            <!-- Login Form -->
            <form id="login-form" action="@Url.Action("Login", "Home")" method="post" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Email</label>
                    <input type="email" name="Email" required 
                        class="w-full bg-[#0a0a0a] border border-white/10 rounded-lg py-3 px-4 text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-700"
                        placeholder="admin@example.com">
                </div>

                <div class="space-y-2">
                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Password</label>
                    <input type="password" name="Password" required 
                        class="w-full bg-[#0a0a0a] border border-white/10 rounded-lg py-3 px-4 text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-700"
                        placeholder="........">
                </div>

                <div class="flex justify-end">
                    <a href="@Url.Action("ForgotPassword", "Home")" class="text-xs text-gray-500 hover:text-brand-500 transition-colors">Forgot Password?</a>
                </div>

                <button type="submit" 
                    class="w-full bg-brand-500 hover:bg-brand-900 text-white font-bold py-4 rounded-lg mt-4 transition-all shadow-[0_4px_20px_rgba(168,85,247,0.4)]">
                    Sign In
                </button>
            </form>

            <!-- Register Form (Hidden by default) -->
            <form id="register-form" action="@Url.Action("Register", "Home")" method="post" class="space-y-6 hidden">
                <div class="space-y-2">
                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Full Name</label>
                    <input type="text" name="FullName" required 
                        class="w-full bg-[#0a0a0a] border border-white/10 rounded-lg py-3 px-4 text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-700"
                        placeholder="John Doe">
                </div>

                <div class="space-y-2">
                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Email</label>
                    <input type="email" name="Email" required 
                        class="w-full bg-[#0a0a0a] border border-white/10 rounded-lg py-3 px-4 text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-700"
                        placeholder="john@example.com">
                </div>

                <div class="space-y-2">
                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Password</label>
                    <input type="password" name="Password" required 
                        class="w-full bg-[#0a0a0a] border border-white/10 rounded-lg py-3 px-4 text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-700"
                        placeholder="........">
                </div>

                <div class="space-y-2">
                    <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Confirm Password</label>
                    <input type="password" name="ConfirmPassword" required 
                        class="w-full bg-[#0a0a0a] border border-white/10 rounded-lg py-3 px-4 text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-700"
                        placeholder="........">
                </div>

                <button type="submit" 
                    class="w-full bg-brand-500 hover:bg-brand-900 text-white font-bold py-4 rounded-lg mt-4 transition-all shadow-[0_4px_20px_rgba(168,85,247,0.4)]">
                    Create Account
                </button>
            </form>

            <div class="mt-8 text-center text-xs text-gray-600">
                <a href="#" onclick="toggleForms(); return false;" id="toggle-link" class="hover:text-brand-500 transition-colors">Create New Account</a>
            </div>
        </div>
    </div>

<script>
// --- LOGIN LOGIC (Added) ---
function openLogin() {
    const modal = document.getElementById('login-modal');
    const mainView = document.getElementById('main-view');
    const trigger = document.getElementById('login-trigger');

    modal.classList.remove('modal-hidden');
    modal.classList.add('modal-visible');
    mainView.classList.add('blur-active');
    trigger.style.opacity = '0';
}

function closeLogin() {
    const modal = document.getElementById('login-modal');
    const mainView = document.getElementById('main-view');
    const trigger = document.getElementById('login-trigger');

    modal.classList.remove('modal-visible');
    modal.classList.add('modal-hidden');
    mainView.classList.remove('blur-active');
    trigger.style.opacity = '';
}

function toggleForms() {
    const loginForm = document.getElementById('login-form');
    const registerForm = document.getElementById('register-form');
    const title = document.getElementById('form-title');
    const subtitle = document.getElementById('form-subtitle');
    const link = document.getElementById('toggle-link');

    if (loginForm.classList.contains('hidden')) {
        // Switch to Login
        loginForm.classList.remove('hidden');
        registerForm.classList.add('hidden');
        title.innerText = "Welcome Back";
        subtitle.innerText = "Enter your credentials";
        link.innerText = "Create New Account";
    } else {
        // Switch to Register
        loginForm.classList.add('hidden');
        registerForm.classList.remove('hidden');
        title.innerText = "Join Us";
        subtitle.innerText = "Create your account";
        link.innerText = "Already have an account? Sign In";
    }
}

// --- SLIDER LOGIC (Original from first block) ---
// --- IMAGE SEQUENCE LOGIC (Modified) ---
const slidesData = [
    { folder: "/Video/v1/", count: 103, prefix: "ezgif-frame-", ext: ".jpg" },
    { folder: "/Video/v2/", count: 143, prefix: "ezgif-frame-", ext: ".jpg" },
    { folder: "/Video/v3/", count: 168, prefix: "ezgif-frame-", ext: ".jpg" }
];

let activeIndex = 0;
let playbackInterval = null;
const sliderContainer = document.getElementById('slider-container');
const indicatorsContainer = document.getElementById('indicators-container');

// Preload cache to avoid flickering
const imageCache = {};

function init() {
    slidesData.forEach((slide, index) => {
        const card = document.createElement('div');
        card.id = `slide-${index}`;
        card.className = 'slide-card absolute inset-0 rounded-sm overflow-hidden bg-black';

        // Using img tag instead of video
        // Initial src is the first frame
        const firstFrame = `${slide.folder}${slide.prefix}001${slide.ext}`;
        
        card.innerHTML = `
            <img id="seq-img-${index}" 
                src="${firstFrame}" 
                class="w-full h-full object-cover opacity-80" 
                alt="Background sequence ${index + 1}">

            <div class="absolute bottom-0 left-0 w-full h-[3px] bg-white/10 ${index === 0 ? 'active-progress' : ''}" id="progress-wrap-${index}">
                <div class="progress-bar shadow-[0_0_15px_#a855f7]" id="progress-${index}"></div>
            </div>
        `;

        sliderContainer.appendChild(card);

        const dot = document.createElement('div');
        dot.id = `dot-${index}`;
        dot.className = index === 0 
            ? 'w-1 h-8 bg-brand-500 rounded-full shadow-[0_0_15px_#a855f7]' 
            : 'w-1 h-1.5 bg-gray-700 rounded-full';
        indicatorsContainer.appendChild(dot);
    });

    lucide.createIcons();
    updatePositions();
    
    // Start playback
    startSequence(0);
}

function startSequence(index) {
    if (playbackInterval) clearInterval(playbackInterval);
    
    // Reset all progress bars
    slidesData.forEach((_, i) => {
        const bar = document.getElementById(`progress-${i}`);
        const wrap = document.getElementById(`progress-wrap-${i}`);
        
        if (i !== index) {
            wrap.classList.remove('active-progress');
            bar.style.width = '0%';
        }
    });

    const slide = slidesData[index];
    const imgElement = document.getElementById(`seq-img-${index}`);
    const progressBar = document.getElementById(`progress-${index}`);
    const progressWrap = document.getElementById(`progress-wrap-${index}`);
    
    progressWrap.classList.add('active-progress');
    
    let currentFrame = 1;
    const totalFrames = slide.count;
    const fps = 24;
    const intervalTime = 1000 / fps;

    // Preload next few images dynamically if not cached
    preloadSequence(index, 1, 5); 

    playbackInterval = setInterval(() => {
        if (currentFrame >= totalFrames) {
            clearInterval(playbackInterval);
            progressWrap.classList.remove('active-progress');
            progressBar.style.width = '100%';
            nextSlide();
            return;
        }

        currentFrame++;
        
        // Pad frame number with leading zeros (3 digits)
        const frameNum = String(currentFrame).padStart(3, '0');
        const src = `${slide.folder}${slide.prefix}${frameNum}${slide.ext}`;
        
        imgElement.src = src;

        // Update progress bar width manually since we handle the timing
        const progress = (currentFrame / totalFrames) * 100;
        progressBar.style.width = `${progress}%`;
        
        // Continuous lookahead preloading
        // Preload 10 frames ahead
        const lookahead = currentFrame + 10;
        if (lookahead <= totalFrames) {
            preloadImage(slide, lookahead);
        }

    }, intervalTime);
}

function preloadImage(slide, frameNumber) {
    const frameStr = String(frameNumber).padStart(3, '0');
    const key = `${slide.folder}${frameStr}`;
    if (!imageCache[key]) {
        const img = new Image();
        img.src = `${slide.folder}${slide.prefix}${frameStr}${slide.ext}`;
        imageCache[key] = img;
    }
}

function preloadSequence(slideIndex, startFrame, count) {
    const slide = slidesData[slideIndex];
    for (let i = 0; i < count; i++) {
        const frame = startFrame + i;
        if (frame <= slide.count) {
            preloadImage(slide, frame);
        }
    }
}

function nextSlide() {
    activeIndex = (activeIndex + 1) % slidesData.length;
    updatePositions();
    startSequence(activeIndex);
}

function updatePositions() {
    slidesData.forEach((_, index) => {
        const card = document.getElementById(`slide-${index}`);
        const dot = document.getElementById(`dot-${index}`);

        let pos = index - activeIndex;
        if (pos > 1) pos -= slidesData.length;
        if (pos < -1) pos += slidesData.length;

        if (pos === 0) {
            card.style.transform = 'translateY(0)';
            card.style.opacity = '1';
            card.style.zIndex = 30;
            dot.className = 'w-1 h-8 bg-brand-500 rounded-full shadow-[0_0_15px_#a855f7] transition-all duration-500';
        } else if (pos === 1) {
            card.style.transform = 'translateY(110%) scale(0.9)';
            card.style.opacity = '0.10';
            card.style.zIndex = 20;
            dot.className = 'w-1 h-1.5 bg-gray-700 rounded-full transition-all duration-500';
        } else if (pos === -1) {
            card.style.transform = 'translateY(-110%) scale(0.9)';
            card.style.opacity = '0.20';
            card.style.zIndex = 20;
            dot.className = 'w-1 h-1.5 bg-gray-700 rounded-full transition-all duration-500';
        } else {
            card.style.opacity = '0';
        }
    });
}

init();

    // Check for server-side messages and open modal if present
    @if (ViewBag.Error != null || ViewBag.Message != null)
    {
        <text>
        document.addEventListener('DOMContentLoaded', function() {
            openLogin();
        });
        </text>
    }
</script>

</body>
</html>
