@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Seamless Gallery with Login</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500&display=swap" rel="stylesheet">

    <script>
        (function () {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif']
                    },
                    colors: {
                        brand: {
                            500: '#a855f7',
                            900: '#581c87'
                        }
                    }
                }
            }
        }
    </script>

    <style>
        /* --- SLIDER STYLES (UNCHANGED) --- */
        .slide-card {
            transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
            will-change: transform, opacity, filter;
        }

        @@keyframes progress {
            from { width: 0%; }
            to { width: 100%; }
        }

        .progress-bar {
            height: 100%;
            background: #a855f7;
            width: 0%;
        }

        .active-progress .progress-bar {
            animation-name: progress;
            animation-timing-function: linear;
        }

        .noise-bg {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        }

        /* --- NEW LOGIN STYLES --- */
        /* Modal Transitions */
        #login-modal {
            transition: opacity 0.5s ease, transform 0.5s ease;
        }
        .modal-hidden {
            opacity: 0;
            pointer-events: none;
            transform: scale(0.95);
        }
        .modal-visible {
            opacity: 1;
            pointer-events: auto;
            transform: scale(1);
        }

        /* Background Blur Transition */
        #main-view {
            transition: filter 0.5s ease;
        }
        .blur-active {
            filter: blur(16px) brightness(0.5);
        }

        /* Button Popup Animation */
        #login-trigger {
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .group:hover #login-trigger {
            opacity: 1;
            transform: translateY(0);
        }
        /* Default state: hidden and slightly down */
        #login-trigger {
            opacity: 0;
            transform: translateY(20px);
        }

        /* Input Styling */
        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active{
            -webkit-box-shadow: 0 0 0 30px #171717 inset !important;
            -webkit-text-fill-color: white !important;
        }

        /* --- MOBILE RESPONSIVENESS --- */
        @@media (max-width: 768px) {
            #desktop-slider-view {
                display: none !important;
            }
            
            #mobile-login-view {
                display: flex !important;
            }

            body {
                overflow-y: auto !important;
                height: auto;
                min-height: 100vh;
                background: #050505;
            }
        }
    </style>
</head>

