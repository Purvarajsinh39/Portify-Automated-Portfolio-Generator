@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Portify</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'], serif: ['Playfair Display', 'serif'] },
                    colors: { brand: { 500: '#a855f7', 900: '#581c87' } }
                }
            }
        }
    </script>
</head>
<body class="bg-[#050505] text-white overflow-hidden h-screen w-screen selection:bg-brand-500 selection:text-white flex items-center justify-center">

    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 w-[800px] h-[800px] bg-brand-900/10 rounded-full blur-[150px] -translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <div class="relative z-10 bg-[#171717] border border-white/10 p-10 rounded-2xl w-full max-w-md shadow-2xl">
        <div class="text-center mb-6">
            <h2 class="text-3xl font-serif italic text-white mb-2">New Password</h2>
            <p class="text-gray-400 text-xs uppercase tracking-widest leading-relaxed">
                OTP verification successful.<br>
                Please enter a new password below.
            </p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-500/10 border border-red-500/50 text-red-500 px-4 py-3 rounded-lg mb-6 text-sm text-center">
                <i data-lucide="alert-circle" class="w-4 h-4 inline-block mr-1 -mt-0.5"></i> @ViewBag.Error
            </div>
        }
        @if (ViewBag.Message != null)
        {
            <div class="bg-green-500/10 border border-green-500/50 text-green-500 px-4 py-3 rounded-lg mb-6 text-sm text-center">
                <i data-lucide="check-circle" class="w-4 h-4 inline-block mr-1 -mt-0.5"></i> @ViewBag.Message
            </div>
        }

        <form action="@Url.Action("ResetPassword", "Home")" method="post" class="space-y-6">
            
            <div class="space-y-2">
                <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">New Password</label>
                <input type="password" name="Password" required 
                    class="w-full bg-[#0a0a0a] border border-white/10 rounded-lg py-4 px-4 text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-800"
                    placeholder="........">
            </div>

            <div class="space-y-2">
                <label class="text-xs uppercase font-bold text-gray-500 tracking-wider">Confirm Password</label>
                <input type="password" name="ConfirmPassword" required 
                    class="w-full bg-[#0a0a0a] border border-white/10 rounded-lg py-4 px-4 text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500 transition-all placeholder-gray-800"
                    placeholder="........">
            </div>

            <button type="submit" 
                class="w-full bg-brand-500 hover:bg-brand-900 text-white font-bold py-4 rounded-lg mt-4 transition-all shadow-[0_4px_20px_rgba(168,85,247,0.4)]">
                Reset Password
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-white/10 flex justify-center">
            <a href="@Url.Action("Login", "Home")" class="flex items-center text-xs text-gray-500 hover:text-white transition-colors group">
                <i data-lucide="arrow-left" class="w-3 h-3 mr-2 group-hover:-translate-x-1 transition-transform"></i> Cancel
            </a>
        </div>
    </div>
    
    <script>lucide.createIcons();</script>
</body>
</html>
