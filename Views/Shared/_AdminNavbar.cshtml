<nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300 border-b border-transparent">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between relative">

        <!-- Logo -->
        <a href="@Url.Action("Admin", "Dashboard")" class="flex items-center gap-2 relative z-50 group">
            <span class="text-2xl font-bold font-serif italic tracking-tight text-gray-900 dark:text-white transition-colors">
                Portify
            </span>
        </a>

        <!-- Center Navigation -->
        @{
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        }
        <div class="hidden md:flex items-center gap-10 absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">

            <a href="@Url.Action("Index", "Home")"
               class="relative text-base font-medium transition-all duration-300 hover:text-brand-500 dark:hover:text-brand-400 hover:-translate-y-0.5
                      after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:bg-brand-500
                      after:transition-all after:duration-300 hover:after:w-full
                      @(currentController == "Home" && currentAction == "Index" ? "text-brand-500 dark:text-brand-400 after:w-full" : "text-gray-600 dark:text-gray-300 after:w-0")">
                Home
            </a>
            
            <a href="@Url.Action("UploadTemplate", "Dashboard")"
               class="relative text-base font-medium transition-all duration-300 hover:text-brand-500 dark:hover:text-brand-400 hover:-translate-y-0.5
                      after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:bg-brand-500
                      after:transition-all after:duration-300 hover:after:w-full
                      @(currentController == "Dashboard" && currentAction == "UploadTemplate" ? "text-brand-500 dark:text-brand-400 after:w-full" : "text-gray-600 dark:text-gray-300 after:w-0")">
                Upload Template
            </a>

            <a href="@Url.Action("Admin", "Dashboard")"
               class="relative text-base font-medium transition-all duration-300 hover:text-brand-500 dark:hover:text-brand-400 hover:-translate-y-0.5
                      after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:bg-brand-500
                      after:transition-all after:duration-300 hover:after:w-full
                      @(currentController == "Dashboard" && currentAction == "Admin" ? "text-brand-500 dark:text-brand-400 after:w-full" : "text-gray-600 dark:text-gray-300 after:w-0")">
                Dashboard
            </a>

            <a href="@Url.Action("UserManagement", "Dashboard")"
               class="relative text-base font-medium transition-all duration-300 hover:text-brand-500 dark:hover:text-brand-400 hover:-translate-y-0.5
                      after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:bg-brand-500
                      after:transition-all after:duration-300 hover:after:w-full
                      @(currentController == "Dashboard" && currentAction == "UserManagement" ? "text-brand-500 dark:text-brand-400 after:w-full" : "text-gray-600 dark:text-gray-300 after:w-0")">
                User Management
            </a>
        </div>

        <!-- Right Section -->
        <div class="flex items-center gap-4 relative z-50">

            <!-- Theme Toggle -->
            <button onclick="toggleTheme()"
                    class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-white/10 text-gray-600 dark:text-gray-300 transition-colors focus:outline-none focus:ring-2 focus:ring-brand-500">
                <i data-lucide="sun" class="hidden dark:block w-5 h-5"></i>
                <i data-lucide="moon" class="block dark:hidden w-5 h-5"></i>
            </button>

            <!-- Username -->
            <span class="text-sm font-medium text-gray-600 dark:text-gray-300 hidden md:block">
                @Session["UserName"]
            </span>

            <!-- Logout Button -->
            <a href="@Url.Action("Logout", "Home")"
               class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold text-black bg-white rounded-lg transition-all duration-200 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-600 shadow-md">
                Logout
            </a>

        </div>
    </div>
</nav>

@if (ViewData["OmitSpacer"] == null || !(bool)ViewData["OmitSpacer"])
{
    <div class="h-24"></div>
}

<script>
    // --- NAVBAR SCROLL LOGIC ---
    document.addEventListener("DOMContentLoaded", function () {
        const nav = document.getElementById('navbar');
        if (nav) {
            window.addEventListener('scroll', () => {
                if (window.scrollY > 20) {
                    nav.classList.add('bg-white/80', 'dark:bg-[#050505]/80', 'backdrop-blur-md', 'border-gray-200', 'dark:border-white/5');
                    nav.classList.remove('border-transparent');
                } else {
                    nav.classList.remove('bg-white/80', 'dark:bg-[#050505]/80', 'backdrop-blur-md', 'border-gray-200', 'dark:border-white/5');
                    nav.classList.add('border-transparent');
                }
            });
        }
    });
</script>
