<nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300 border-b border-transparent">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between relative">

        <!-- Logo -->
        <a href="@Url.Action("Index", "Dashboard")" class="flex items-center gap-2 relative z-50 group">
            <span class="text-2xl font-bold font-serif italic tracking-tight text-gray-900 dark:text-white transition-colors">
                Portify
            </span>
        </a>

        <!-- Center Navigation -->
        @{
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        }
        <div class="hidden md:flex items-center gap-10 absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">

            <a href="@Url.Action("Index", "Home")"
               class="relative text-base font-medium transition-all duration-300 hover:text-brand-500 dark:hover:text-brand-400 hover:-translate-y-0.5
                      after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:bg-brand-500
                      after:transition-all after:duration-300 hover:after:w-full
                      @(currentController == "Home" && currentAction == "Index" ? "text-brand-500 dark:text-brand-400 after:w-full" : "text-gray-600 dark:text-gray-300 after:w-0")">
                Home
            </a>

            <a href="@Url.Action("Explore", "Dashboard")"
               class="relative text-base font-medium transition-all duration-300 hover:text-brand-500 dark:hover:text-brand-400 hover:-translate-y-0.5
                      after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:bg-brand-500
                      after:transition-all after:duration-300 hover:after:w-full
                      @(currentController == "Dashboard" && currentAction == "Explore" ? "text-brand-500 dark:text-brand-400 after:w-full" : "text-gray-600 dark:text-gray-300 after:w-0")">
                Explore
            </a>

            <a href="@Url.Action("Index", "Dashboard")"
               class="relative text-base font-medium transition-all duration-300 hover:text-brand-500 dark:hover:text-brand-400 hover:-translate-y-0.5
                      after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:bg-brand-500
                      after:transition-all after:duration-300 hover:after:w-full
                      @(currentController == "Dashboard" && currentAction == "Index" ? "text-brand-500 dark:text-brand-400 after:w-full" : "text-gray-600 dark:text-gray-300 after:w-0")">
                Dashboard
            </a>

            <a href="@Url.Action("MyProfile", "Dashboard")"
               class="relative text-base font-medium transition-all duration-300 hover:text-brand-500 dark:hover:text-brand-400 hover:-translate-y-0.5
                      after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:bg-brand-500
                      after:transition-all after:duration-300 hover:after:w-full
                      @(currentController == "Dashboard" && currentAction == "MyProfile" ? "text-brand-500 dark:text-brand-400 after:w-full" : "text-gray-600 dark:text-gray-300 after:w-0")">
                My Profile
            </a>

        </div>

        <!-- Right Section -->
        <div class="flex items-center gap-2 md:gap-4 relative z-50">

            <!-- Theme Toggle -->
            <button onclick="toggleTheme()"
                    class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-white/10 text-gray-600 dark:text-gray-300 transition-colors focus:outline-none focus:ring-2 focus:ring-brand-500">
                <i data-lucide="sun" class="hidden dark:block w-5 h-5"></i>
                <i data-lucide="moon" class="block dark:hidden w-5 h-5"></i>
            </button>

            <!-- Username -->
            <span class="text-sm font-medium text-gray-600 dark:text-gray-300 hidden md:block">
                @Session["UserName"]
            </span>

            <!-- Logout Button (Desktop) -->
            <a href="@Url.Action("Logout", "Home")"
               class="hidden md:inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold text-black bg-white rounded-lg transition-all duration-200 hover:bg-red-500 hover:text-white focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-600 shadow-md">
                Logout
            </a>

            <!-- Mobile Menu Toggle -->
            <button onclick="toggleMobileMenu()"
                    class="md:hidden p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors focus:outline-none">
                <i data-lucide="menu" id="menu-icon" class="w-6 h-6"></i>
                <i data-lucide="x" id="close-icon" class="hidden w-6 h-6"></i>
            </button>

        </div>
    </div>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" 
         class="fixed inset-0 z-40 md:hidden invisible opacity-0 transition-all duration-300 pointer-events-none">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-white/95 dark:bg-[#050505]/95 backdrop-blur-xl"></div>
        
        <!-- Menu Content -->
        <div class="relative h-full flex flex-col justify-center items-center p-8 gap-8">
            <nav class="flex flex-col items-center gap-8 text-center w-full max-w-sm">
                <a href="@Url.Action("Index", "Home")" onclick="toggleMobileMenu()"
                   class="text-2xl font-serif italic text-gray-900 dark:text-white hover:text-brand-500 transition-colors">Home</a>
                <a href="@Url.Action("Explore", "Dashboard")" onclick="toggleMobileMenu()"
                   class="text-2xl font-serif italic text-gray-900 dark:text-white hover:text-brand-500 transition-colors">Explore</a>
                <a href="@Url.Action("Index", "Dashboard")" onclick="toggleMobileMenu()"
                   class="text-2xl font-serif italic text-gray-900 dark:text-white hover:text-brand-500 transition-colors">Dashboard</a>
                <a href="@Url.Action("MyProfile", "Dashboard")" onclick="toggleMobileMenu()"
                   class="text-2xl font-serif italic text-gray-900 dark:text-white hover:text-brand-500 transition-colors">My Profile</a>
                
                <div class="w-12 h-px bg-gray-200 dark:bg-white/10 my-2"></div>
                
                <div class="flex flex-col items-center gap-2">
                    <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Signed in as</span>
                    <span class="text-lg font-bold text-gray-900 dark:text-white mb-4">@Session["UserName"]</span>
                    <a href="@Url.Action("Logout", "Home")"
                       class="text-lg font-semibold text-red-600 dark:text-red-400 hover:text-red-700 transition-colors">
                        Sign Out
                    </a>
                </div>
            </nav>
        </div>
    </div>
</nav>

@if (ViewData["OmitSpacer"] == null || !(bool)ViewData["OmitSpacer"])
{
    <div class="h-24"></div>
}

<script>
    // --- NAVBAR SCROLL LOGIC ---
    document.addEventListener("DOMContentLoaded", function () {
        const nav = document.getElementById('navbar');
        if (nav) {
            window.addEventListener('scroll', () => {
                if (window.scrollY > 20) {
                    nav.classList.add('bg-white/80', 'dark:bg-[#050505]/80', 'backdrop-blur-md', 'border-gray-200', 'dark:border-white/5');
                    nav.classList.remove('border-transparent');
                } else {
                    nav.classList.remove('bg-white/80', 'dark:bg-[#050505]/80', 'backdrop-blur-md', 'border-gray-200', 'dark:border-white/5');
                    nav.classList.add('border-transparent');
                }
            });
        }
    });

    // --- MOBILE MENU LOGIC ---
    function toggleMobileMenu() {
        const menu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');
        const isHidden = menu.classList.contains('invisible');

        if (isHidden) {
            // Open
            menu.classList.remove('invisible', 'opacity-0', 'pointer-events-none');
            menu.classList.add('opacity-100', 'pointer-events-auto');
            menuIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
            document.body.style.overflow = 'hidden'; // Prevent scrolling
        } else {
            // Close
            menu.classList.add('invisible', 'opacity-0', 'pointer-events-none');
            menu.classList.remove('opacity-100', 'pointer-events-auto');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            document.body.style.overflow = ''; // Restore scrolling
        }
    }
</script>
