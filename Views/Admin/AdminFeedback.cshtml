@model List<Portify.Models.Feedback>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feedback Management | Portify Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <script>
        (function () {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif']
                    },
                    colors: {
                        brand: {
                            50: '#faf5ff',
                            100: '#f3e8ff',
                            300: '#d8b4fe',
                            500: '#a855f7',
                            600: '#9333ea',
                            900: '#581c87'
                        }
                    },
                    animation: {
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    }
                }
            }
        }
    </script>

    <style>
        .noise-bg {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        }

        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .dark .glass {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .table-glass-row {
            transition: all 0.3s ease;
        }

            .table-glass-row:hover {
                background: rgba(168, 85, 247, 0.05);
            }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #050505;
        }

        ::-webkit-scrollbar-thumb {
            background: #a855f7;
            border-radius: 10px;
        }
    </style>
</head>

<body class="bg-white dark:bg-[#050505] text-gray-900 dark:text-white transition-colors duration-500 selection:bg-brand-500 selection:text-white min-h-screen">
    @Html.Partial("~/Views/Shared/_PageTransitions.cshtml")

    <!-- Background Ambient Effects -->
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute top-[-10%] right-[10%] w-[40%] h-[40%] bg-brand-500/10 rounded-full blur-[120px] animate-pulse-slow"></div>
        <div class="absolute bottom-[-10%] left-[10%] w-[40%] h-[40%] bg-blue-500/10 rounded-full blur-[120px] animate-pulse-slow"></div>
        <div class="absolute inset-0 noise-bg opacity-30 dark:opacity-20"></div>
    </div>

    <div class="relative z-10">
        @Html.Partial("~/Views/Shared/_AdminNavbar.cshtml")

        <main class="max-w-7xl mx-auto px-6 pt-32 pb-20">

            <!-- Page Header -->
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
                <div>
                    <h2 class="text-xs uppercase tracking-[0.4em] text-brand-500 font-bold mb-2">Administration</h2>
                    <h1 class="text-4xl md:text-5xl font-serif italic text-gray-900 dark:text-white">User Feedback</h1>
                </div>

                <div class="text-sm text-gray-500 dark:text-gray-400 font-sans">
                    Total Ratings: <span class="font-bold text-gray-900 dark:text-white">@Model.Count</span>
                </div>
            </div>

            <!-- Glass Table Container -->
            <div class="glass rounded-3xl overflow-hidden shadow-2xl relative">

                <!-- Gradient Line Top -->
                <div class="h-1 w-full bg-gradient-to-r from-transparent via-brand-500 to-transparent opacity-50"></div>

                <div class="overflow-x-auto p-1">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b border-gray-200/50 dark:border-white/5 text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400 font-sans">
                                <th class="p-6 font-semibold">User</th>
                                <th class="p-6 font-semibold">Template</th>
                                <th class="p-6 font-semibold text-center">Rating</th>
                                <th class="p-6 font-semibold">Message</th>
                                <th class="p-6 font-semibold text-right">Date</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            @foreach (var feedback in Model)
                            {
                                <tr class="table-glass-row border-b border-gray-100 dark:border-white/5 last:border-0 group">
                                    <td class="p-6">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-gray-100 to-gray-200 dark:from-white/10 dark:to-white/5 flex items-center justify-center text-xs font-bold font-serif italic">
                                                @(string.IsNullOrEmpty(feedback.UserName) ? "?" : feedback.UserName.Substring(0, 1))
                                            </div>
                                            <span class="font-medium text-gray-900 dark:text-gray-200">@feedback.UserName</span>
                                        </div>
                                    </td>

                                    <td class="p-6 text-gray-600 dark:text-gray-400 font-medium">
                                        @feedback.TemplateName
                                    </td>

                                    <td class="p-6 text-center">
                                        <div class="flex items-center justify-center gap-0.5">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i data-lucide="star" class="w-4 h-4 @(i <= feedback.Rating ? "text-yellow-500 fill-current" : "text-gray-200 dark:text-gray-800")"></i>
                                            }
                                        </div>
                                    </td>

                                    <td class="p-6 text-gray-600 dark:text-gray-400 max-w-xs truncate" title="@feedback.Message">
                                        @feedback.Message
                                    </td>

                                    <td class="p-6 text-right text-gray-400 font-mono text-xs">
                                        @feedback.CreatedAt.ToString("dd MMM yyyy HH:mm")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.Count == 0)
                {
                    <div class="p-12 text-center text-gray-500 dark:text-gray-400">
                        <i data-lucide="inbox" class="w-12 h-12 mx-auto mb-4 opacity-50"></i>
                        <p class="text-lg font-serif italic">No feedback records found.</p>
                    </div>
                }
            </div>

        </main>
    </div>

    <script>
        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        }
        lucide.createIcons();
    </script>
</body>
</html>

