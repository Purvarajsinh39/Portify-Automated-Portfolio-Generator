@model List<Portify.Models.User>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management | Portify Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <script>
        (function () {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif']
                    },
                    colors: {
                        brand: {
                            50: '#faf5ff',
                            100: '#f3e8ff',
                            300: '#d8b4fe',
                            500: '#a855f7',
                            600: '#9333ea',
                            900: '#581c87'
                        }
                    },
                    animation: {
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    }
                }
            }
        }
    </script>

    <style>
        .noise-bg {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        }

        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .dark .glass {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .table-glass-row {
            transition: all 0.3s ease;
        }

            .table-glass-row:hover {
                background: rgba(168, 85, 247, 0.05); /* brand-500 at 5% */
            }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #050505;
        }

        ::-webkit-scrollbar-thumb {
            background: #a855f7;
            border-radius: 10px;
        }
    </style>
</head>

<body class="bg-white dark:bg-[#050505] text-gray-900 dark:text-white transition-colors duration-500 selection:bg-brand-500 selection:text-white min-h-screen">

    <!-- Background Ambient Effects -->
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute top-[-10%] right-[10%] w-[40%] h-[40%] bg-brand-500/10 rounded-full blur-[120px] animate-pulse-slow"></div>
        <div class="absolute bottom-[-10%] left-[10%] w-[40%] h-[40%] bg-blue-500/10 rounded-full blur-[120px] animate-pulse-slow"></div>
        <div class="absolute inset-0 noise-bg opacity-30 dark:opacity-20"></div>
        <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20"></div>
    </div>

    <div class="relative z-10">
        @Html.Partial("~/Views/Shared/_AdminNavbar.cshtml")

        <main class="max-w-7xl mx-auto px-6 pt-32 pb-20">

            <!-- Page Header -->
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
                <div>
                    <h2 class="text-xs uppercase tracking-[0.4em] text-brand-500 font-bold mb-2">Administration</h2>
                    <h1 class="text-4xl md:text-5xl font-serif italic text-gray-900 dark:text-white">User Management</h1>
                </div>

                <!-- Optional: Add a subtle stat counter or filter here if needed later -->
                <div class="text-sm text-gray-500 dark:text-gray-400 font-sans">
                    Total Users: <span class="font-bold text-gray-900 dark:text-white">@Model.Count</span>
                </div>
            </div>

            <!-- Glass Table Container -->
            <div class="glass rounded-3xl overflow-hidden shadow-2xl relative">

                <!-- Gradient Line Top -->
                <div class="h-1 w-full bg-gradient-to-r from-transparent via-brand-500 to-transparent opacity-50"></div>

                <div class="overflow-x-auto p-1">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b border-gray-200/50 dark:border-white/5 text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400 font-sans">
                                <th class="p-6 font-semibold">ID</th>
                                <th class="p-6 font-semibold">Full Name</th>
                                <th class="p-6 font-semibold">Email</th>
                                <th class="p-6 font-semibold">Role</th>
                                <th class="p-6 font-semibold">Status</th>
                                <th class="p-6 font-semibold text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            @foreach (var user in Model)
                            {
                                <tr class="table-glass-row border-b border-gray-100 dark:border-white/5 last:border-0 group">
                                    <td class="p-6 font-mono text-gray-400 dark:text-gray-500 group-hover:text-brand-500 transition-colors">
                                        #@user.Id
                                    </td>

                                    <td class="p-6">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-gray-100 to-gray-200 dark:from-white/10 dark:to-white/5 flex items-center justify-center text-xs font-bold font-serif italic">
                                                @user.FullName.Substring(0, 1)
                                            </div>
                                            <span class="font-medium text-gray-900 dark:text-gray-200">@user.FullName</span>
                                        </div>
                                    </td>

                                    <td class="p-6 text-gray-600 dark:text-gray-400">
                                        @user.Email
                                    </td>

                                    <td class="p-6">
                                        <span class="@(user.Role == "Admin" ? "text-brand-600 dark:text-brand-400 font-bold drop-shadow-[0_0_8px_rgba(168,85,247,0.3)]" : "text-gray-500 dark:text-gray-500")">
                                            @user.Role
                                        </span>
                                    </td>

                                    <td class="p-6">
                                        @if (user.IsBlocked)
                                        {
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-500/20">
                                                <span class="w-1.5 h-1.5 rounded-full bg-red-500 mr-2"></span>
                                                Blocked
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-50 dark:bg-green-500/10 text-green-600 dark:text-green-400 border border-green-200 dark:border-green-500/20">
                                                <span class="w-1.5 h-1.5 rounded-full bg-green-500 mr-2 shadow-[0_0_8px_rgba(34,197,94,0.4)]"></span>
                                                Active
                                            </span>
                                        }
                                    </td>

                                    <td class="p-6 text-right">
                                        @if (user.Role != "Admin")
                                        {
                                            if (user.IsBlocked)
                                            {
                                                <form action="@Url.Action("UnblockUser", "Dashboard")" method="post" class="inline">
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit" class="group/btn relative inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-gray-500 hover:text-green-500 dark:text-gray-400 dark:hover:text-green-400 transition-colors">
                                                        <span class="group-hover/btn:underline decoration-green-500/50 underline-offset-4">Unblock</span>
                                                        <i data-lucide="unlock" class="w-3 h-3 group-hover/btn:scale-110 transition-transform"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form action="@Url.Action("BlockUser", "Dashboard")" method="post" class="inline">
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit" class="group/btn relative inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-gray-500 hover:text-red-500 dark:text-gray-400 dark:hover:text-red-400 transition-colors">
                                                        <span class="group-hover/btn:underline decoration-red-500/50 underline-offset-4">Block</span>
                                                        <i data-lucide="lock" class="w-3 h-3 group-hover/btn:scale-110 transition-transform"></i>
                                                    </button>
                                                </form>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-gray-300 dark:text-gray-700 text-xs italic cursor-not-allowed">Protected</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.Count == 0)
                {
                    <div class="p-12 text-center text-gray-500 dark:text-gray-400">
                        <i data-lucide="users" class="w-12 h-12 mx-auto mb-4 opacity-50"></i>
                        <p class="text-lg font-serif italic">No users found in the system.</p>
                    </div>
                }
            </div>

        </main>
    </div>

    <!-- Theme Toggle logic reserved from original setup -->
    <script>
        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        }

        // Initial Theme Load handled in <head> for FOUC prevention

        // Initialize Icons
        lucide.createIcons();
    </script>
</body>
</html>