@model Portify.Models.AdminDashboardViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics | Portify Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <script>
        (function () {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif']
                    },
                    colors: {
                        brand: {
                            50: '#faf5ff',
                            100: '#f3e8ff',
                            300: '#d8b4fe',
                            500: '#a855f7',
                            600: '#9333ea',
                            900: '#581c87'
                        }
                    },
                    animation: {
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'float': 'float 6s ease-in-out infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        .noise-bg {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        }

        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .dark .glass {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #050505; }
        ::-webkit-scrollbar-thumb { background: #a855f7; border-radius: 10px; }
    </style>
</head>

<body class="bg-white dark:bg-[#050505] text-gray-900 dark:text-white transition-colors duration-500 selection:bg-brand-500 selection:text-white min-h-screen flex flex-col">
    @Html.Partial("~/Views/Shared/_PageTransitions.cshtml")

    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute top-[20%] left-[20%] w-[40%] h-[40%] bg-brand-500/10 rounded-full blur-[120px] animate-pulse-slow"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-500/10 rounded-full blur-[120px] animate-pulse-slow" style="animation-delay: 1s;"></div>
        <div class="absolute inset-0 noise-bg opacity-30 dark:opacity-20"></div>
    </div>

    <div class="relative z-10 flex-grow flex flex-col">
        @Html.Partial("~/Views/Shared/_AdminNavbar.cshtml")

        <main class="flex-grow p-6 lg:p-12">
            <div class="max-w-7xl mx-auto space-y-8">
                
                <!-- Page Header -->
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
                    <div>
                        <h2 class="text-xs uppercase tracking-[0.4em] text-brand-500 font-bold mb-2">Platform Overview</h2>
                        <h1 class="text-4xl font-serif italic text-gray-900 dark:text-white">Admin Dashboard</h1>
                    </div>
                    <div class="text-sm text-gray-500 dark:text-gray-400 font-medium">
                        Last synced: @DateTime.Now.ToString("HH:mm")
                    </div>
                </div>

                <!-- Stats Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Total Users -->
                    <div class="glass p-6 rounded-3xl border border-white/20 shadow-xl group hover:scale-[1.02] transition-transform duration-300">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Users</p>
                                <h3 class="text-3xl font-bold mt-1 text-gray-900 dark:text-white">@Model.TotalUsers</h3>
                            </div>
                            <div class="p-3 rounded-2xl bg-brand-500/10 text-brand-500">
                                <i data-lucide="users" class="w-6 h-6"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Portfolios Created -->
                    <div class="glass p-6 rounded-3xl border border-white/20 shadow-xl group hover:scale-[1.02] transition-transform duration-300">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Portfolios</p>
                                <h3 class="text-3xl font-bold mt-1 text-gray-900 dark:text-white">@Model.TotalPortfolios</h3>
                            </div>
                            <div class="p-3 rounded-2xl bg-blue-500/10 text-blue-500">
                                <i data-lucide="briefcase" class="w-6 h-6"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Active Templates -->
                    <div class="glass p-6 rounded-3xl border border-white/20 shadow-xl group hover:scale-[1.02] transition-transform duration-300">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Templates</p>
                                <h3 class="text-3xl font-bold mt-1 text-gray-900 dark:text-white">@Model.TotalTemplates</h3>
                            </div>
                            <div class="p-3 rounded-2xl bg-purple-500/10 text-purple-500">
                                <i data-lucide="layout" class="w-6 h-6"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Platform Rating -->
                    <div class="glass p-6 rounded-3xl border border-white/20 shadow-xl group hover:scale-[1.02] transition-transform duration-300">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Avg Rating</p>
                                <h3 class="text-3xl font-bold mt-1 text-gray-900 dark:text-white">@Model.AverageRating.ToString("F1")<span class="text-lg text-gray-400"> / 5</span></h3>
                            </div>
                            <div class="p-3 rounded-2xl bg-amber-500/10 text-amber-500">
                                <i data-lucide="star" class="w-6 h-6"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts Section -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <!-- Growth Trends (Line Chart) -->
                    <div class="lg:col-span-2 glass p-8 rounded-3xl shadow-xl">
                        <div class="flex items-center justify-between mb-8">
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 dark:text-white">Growth Trends</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400">New creations & registrations over last 14 days</p>
                            </div>
                            <i data-lucide="trending-up" class="w-6 h-6 text-brand-500"></i>
                        </div>
                        <div class="h-[300px] w-full">
                            <canvas id="growthChart"></canvas>
                        </div>
                    </div>

                    <!-- Template Performance (Doughnut Chart) -->
                    <div class="glass p-8 rounded-3xl shadow-xl">
                        <div class="flex items-center justify-between mb-8">
                            <div>
                                <h3 class="text-xl font-bold text-gray-900 dark:text-white">Popularity</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400">Template usage share</p>
                            </div>
                            <i data-lucide="pie-chart" class="w-6 h-6 text-purple-500"></i>
                        </div>
                        <div class="h-[300px] w-full flex items-center justify-center">
                            <canvas id="templateChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions Area -->
                <div class="glass p-8 rounded-3xl shadow-xl flex flex-wrap items-center justify-center gap-6">
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white w-full text-center lg:text-left lg:w-auto">Quick Shortcuts</h3>
                    
                    <a href="@Url.Action("UserManagement", "Dashboard")" class="flex items-center gap-3 px-6 py-3 rounded-2xl bg-white/50 dark:bg-white/5 hover:bg-brand-50 dark:hover:bg-brand-500/10 border border-gray-200/50 dark:border-white/5 transition-all group">
                        <i data-lucide="users" class="w-5 h-5 text-brand-500"></i>
                        <span class="font-medium">User Directory</span>
                    </a>

                    <a href="@Url.Action("ManageTemplates", "Dashboard")" class="flex items-center gap-3 px-6 py-3 rounded-2xl bg-white/50 dark:bg-white/5 hover:bg-brand-50 dark:hover:bg-brand-500/10 border border-gray-200/50 dark:border-white/5 transition-all group">
                        <i data-lucide="layout-template" class="w-5 h-5 text-blue-500"></i>
                        <span class="font-medium">Template Studio</span>
                    </a>

                    <a href="@Url.Action("AdminFeedback", "Dashboard")" class="flex items-center gap-3 px-6 py-3 rounded-2xl bg-white/50 dark:bg-white/5 hover:bg-brand-50 dark:hover:bg-brand-500/10 border border-gray-200/50 dark:border-white/5 transition-all group">
                        <i data-lucide="message-square" class="w-5 h-5 text-purple-500"></i>
                        <span class="font-medium">User Feedback</span>
                    </a>
                </div>

            </div>
        </main>
    </div>

    <script>
        // Data Preparation from Model
        const dailyLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.DailyPortfolios.Select(s => s.Date.ToString("MMM dd")).ToList()));
        const portfolioData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.DailyPortfolios.Select(s => s.Count).ToList()));
        const registrationData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.DailyRegistrations.Select(s => s.Count).ToList()));

        const templateLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.TemplateUsage.Select(s => s.TemplateName).ToList()));
        const templateCounts = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.TemplateUsage.Select(s => s.UsageCount).ToList()));

        // Theme-aware colors
        const isDark = document.documentElement.classList.contains('dark');
        const textColor = isDark ? '#9ca3af' : '#4b5563';
        const gridColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';

        // Common Chart Defaults
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.color = textColor;

        // Growth Chart (Line)
        new Chart(document.getElementById('growthChart'), {
            type: 'line',
            data: {
                labels: dailyLabels,
                datasets: [
                    {
                        label: 'Portfolios Created',
                        data: portfolioData,
                        borderColor: '#a855f7',
                        backgroundColor: 'rgba(168, 85, 247, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 4,
                        pointBackgroundColor: '#a855f7'
                    },
                    {
                        label: 'New Users',
                        data: registrationData,
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 4,
                        pointBackgroundColor: '#3b82f6'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'top', align: 'end', labels: { boxWidth: 10, usePointStyle: true } }
                },
                scales: {
                    y: { grid: { color: gridColor }, border: { display: false } },
                    x: { grid: { display: false } }
                }
            }
        });

        // Template Chart (Doughnut)
        new Chart(document.getElementById('templateChart'), {
            type: 'doughnut',
            data: {
                labels: templateLabels,
                datasets: [{
                    data: templateCounts,
                    backgroundColor: [
                        '#a855f7', '#3b82f6', '#8b5cf6', '#6366f1', '#ec4899', '#f43f5e'
                    ],
                    borderWidth: 0,
                    hoverOffset: 20
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '70%',
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 10, usePointStyle: true, padding: 20 } }
                }
            }
        });

        lucide.createIcons();
    </script>
</body>
</html>
