@model List<Portify.Models.Template>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Explore | Portify</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <script>
        (function () {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif']
                    },
                    colors: {
                        brand: {
                            50: '#faf5ff',
                            100: '#f3e8ff',
                            300: '#d8b4fe',
                            500: '#a855f7',
                            600: '#9333ea',
                            900: '#581c87'
                        }
                    },
                    animation: {
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    }
                }
            }
        }
    </script>
    <style>
        .noise-bg {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        }
        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }
        .dark .glass {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #050505; }
        ::-webkit-scrollbar-thumb { background: #a855f7; border-radius: 10px; }

        .toast { animation: toastIn 0.5s ease forwards, toastOut 0.4s ease 3s forwards; }
        @@keyframes toastIn {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes toastOut {
            from { opacity: 1; transform: translateY(0); }
            to { opacity: 0; transform: translateY(-20px); }
        }
    </style>
</head>
<body class="bg-white dark:bg-[#050505] text-gray-900 dark:text-white transition-colors duration-500 min-h-screen flex flex-col">
    @Html.Partial("~/Views/Shared/_PageTransitions.cshtml")

    <!-- Background Ambient Effects -->
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute top-[20%] left-[20%] w-[40%] h-[40%] bg-brand-500/10 rounded-full blur-[120px] animate-pulse-slow"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-500/10 rounded-full blur-[120px] animate-pulse-slow" style="animation-delay: 1s;"></div>
        <div class="absolute inset-0 noise-bg opacity-30 dark:opacity-20"></div>
    </div>

    <div class="relative z-10 flex-grow flex flex-col">
        @Html.Partial("~/Views/Shared/_UserNavbar.cshtml")

        <main class="flex-grow p-6 sm:p-10 max-w-7xl mx-auto w-full">

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="toast fixed top-28 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-2xl glass shadow-2xl border border-red-500/20"
                     style="animation: toastIn 0.5s ease forwards, toastOut 0.4s ease 3s forwards;">
                    <div class="w-8 h-8 rounded-full bg-red-500/10 flex items-center justify-center">
                        <i data-lucide="alert-circle" class="w-4 h-4 text-red-500"></i>
                    </div>
                    <span class="text-sm font-medium text-red-600 dark:text-red-400">@TempData["ErrorMessage"]</span>
                </div>
            }
            
            <div class="mb-10 text-center">
                <h1 class="text-4xl md:text-5xl font-serif italic mb-4">
                    Explore <span class="not-italic text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-blue-600 dark:from-brand-400 dark:to-blue-400">Templates</span>
                </h1>
                <p class="text-gray-600 dark:text-gray-400 text-lg">Browse our collection of beautiful portfolio templates</p>
            </div>

            <!-- Dummy Filters Section -->
            <div class="glass rounded-2xl p-6 mb-10 flex flex-col md:flex-row gap-4 items-center justify-between">
                <div class="w-full md:w-1/3 relative">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
                    <input type="text" placeholder="Search by template name..." class="w-full pl-10 pr-4 py-2 rounded-xl border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-white/5 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-shadow">
                </div>
                <div class="flex gap-4 w-full md:w-auto">
                    <select class="px-4 py-2 rounded-xl border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-white/5 focus:outline-none focus:ring-2 focus:ring-brand-500 text-gray-700 dark:text-gray-300">
                        <option value="">Templates Uploaded (Newest)</option>
                        <option value="oldest">Templates Uploaded (Oldest)</option>
                    </select>
                    <select class="px-4 py-2 rounded-xl border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-white/5 focus:outline-none focus:ring-2 focus:ring-brand-500 text-gray-700 dark:text-gray-300">
                        <option value="">Security Level (All)</option>
                        <option value="high">High Security</option>
                        <option value="standard">Standard</option>
                    </select>
                </div>
            </div>

            <!-- Templates Grid: 3 items in a row -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var template in Model)
                    {
                        var templateName = template.Name;
                        var htmlPath = Url.Content(template.FilePath);
                        <div class="glass rounded-2xl overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
                            <!-- Template Live Preview -->
                            <div class="h-48 relative flex items-center justify-center overflow-hidden bg-white">
                                <div class="absolute inset-0 w-[400%] h-[400%] origin-top-left scale-[0.25] pointer-events-none">
                                    <iframe src="@htmlPath" class="w-full h-full border-0 pointer-events-none" scrolling="no"></iframe>
                                </div>
                                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center opacity-0 group-hover:opacity-100 z-10">
                                    <a href="@htmlPath" target="_blank" class="px-4 py-2 bg-white text-gray-900 font-medium rounded-lg shadow-lg hover:bg-gray-50 transition-colors">Preview</a>
                                </div>
                            </div>
                            <div class="p-5 border-t border-gray-100 dark:border-white/5 relative z-20 bg-white/50 dark:bg-black/50 backdrop-blur-md">
                                <h3 class="text-xl font-bold mb-2">@templateName</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">@(string.IsNullOrEmpty(template.Description) ? "A beautiful portfolio template." : template.Description)</p>
                                <div class="flex items-center justify-between">
                                    <div class="flex gap-3">
                                        <span class="text-xs font-semibold px-2 py-1 bg-brand-100 text-brand-600 dark:bg-brand-900/30 dark:text-brand-300 rounded-md">Free</span>
                                        <button onclick="openFeedbackModal(@template.Id, '@templateName')" class="text-gray-400 hover:text-yellow-500 transition-colors flex items-center gap-1 group/rate" title="Rate this template">
                                            <i data-lucide="star" class="w-4 h-4 group-hover/rate:fill-current"></i>
                                            <span class="text-[10px] font-bold opacity-0 group-hover/rate:opacity-100 transition-opacity">Submit Rating</span>
                                        </button>
                                    </div>
                                    <a href="@Url.Action("Editor", "Portfolio", new { templateId = template.Id })" class="text-brand-500 hover:text-brand-600 dark:hover:text-brand-400 flex items-center gap-1 text-sm font-medium transition-colors">
                                        Use Template <i data-lucide="arrow-right" class="w-4 h-4"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-span-1 sm:grid-cols-2 lg:col-span-3 text-center py-20 text-gray-500 dark:text-gray-400">
                        <i data-lucide="inbox" class="w-16 h-16 mx-auto mb-4 opacity-50"></i>
                        <p>No templates found in the Templates directory.</p>
                    </div>
                }
            </div>

        </main>
    </div>

    <!-- Feedback Modal -->
    <div id="feedbackModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeFeedbackModal()"></div>
        <div class="glass relative w-full max-w-md rounded-3xl p-8 shadow-2xl animate-in fade-in zoom-in duration-300">
            <h2 class="text-2xl font-serif italic mb-2">Rate <span id="modalTemplateName" class="not-italic text-brand-500">Template</span></h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">How was your experience with this template?</p>
            
            <input type="hidden" id="modalTemplateId" />
            
            <div class="flex justify-center gap-2 mb-6" id="starRating">
                @for (int i = 1; i <= 5; i++)
                {
                    <button onclick="setRating(@i)" class="star-btn p-1 transition-transform hover:scale-110" data-rating="@i">
                        <i data-lucide="star" class="w-8 h-8 text-gray-300 dark:text-gray-700"></i>
                    </button>
                }
            </div>

            <textarea id="feedbackMessage" rows="4" placeholder="Tell us more (optional)..." 
                      class="w-full p-4 rounded-2xl border border-gray-200 dark:border-white/10 bg-white/50 dark:bg-white/5 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-shadow mb-6 text-sm dark:text-white"></textarea>

            <div class="flex gap-4">
                <button onclick="closeFeedbackModal()" class="flex-1 py-3 rounded-xl border border-gray-200 dark:border-white/10 font-medium hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">Cancel</button>
                <button onclick="submitFeedback()" id="submitBtn" class="flex-1 py-3 rounded-xl bg-brand-600 text-white font-medium hover:bg-brand-700 shadow-lg shadow-brand-500/20 transition-all flex items-center justify-center gap-2">
                    Submit
                </button>
            </div>
        </div>
    </div>

    <script>
        let currentRating = 0;

        function openFeedbackModal(id, name) {
            document.getElementById('modalTemplateId').value = id;
            document.getElementById('modalTemplateName').innerText = name;
            document.getElementById('feedbackModal').classList.remove('hidden');
            setRating(0); // Reset
            document.getElementById('feedbackMessage').value = '';
        }

        function closeFeedbackModal() {
            document.getElementById('feedbackModal').classList.add('hidden');
        }

        function setRating(rating) {
            currentRating = rating;
            const stars = document.querySelectorAll('.star-btn');
            stars.forEach((star, index) => {
                const icon = star.querySelector('svg') || star.querySelector('i');
                if (icon) {
                    if (index < rating) {
                        icon.classList.add('text-yellow-400', 'fill-current');
                        icon.classList.remove('text-gray-300', 'dark:text-gray-700');
                    } else {
                        icon.classList.remove('text-yellow-400', 'fill-current');
                        icon.classList.add('text-gray-300', 'dark:text-gray-700');
                    }
                }
            });
        }

        async function submitFeedback() {
            const templateId = document.getElementById('modalTemplateId').value;
            const message = document.getElementById('feedbackMessage').value;
            const submitBtn = document.getElementById('submitBtn');

            if (currentRating === 0) {
                alert("Please select a rating.");
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Submitting...';
            lucide.createIcons();

            try {
                const response = await fetch('@Url.Action("SubmitFeedback", "Portfolio")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `templateId=${templateId}&rating=${currentRating}&message=${encodeURIComponent(message)}`
                });

                const result = await response.json();
                if (result.success) {
                    showToast("Success", result.message, "success");
                    closeFeedbackModal();
                } else {
                    showToast("Error", result.message, "error");
                }
            } catch (error) {
                showToast("Error", "Something went wrong.", "error");
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Submit';
                lucide.createIcons();
            }
        }

        function showToast(title, message, type) {
            const toast = document.createElement('div');
            toast.className = `toast fixed top-28 right-6 z-[200] flex items-center gap-3 px-5 py-3 rounded-2xl glass shadow-2xl border ${type === 'success' ? 'border-green-500/20' : 'border-red-500/20'}`;
            toast.innerHTML = `
                <div class="w-8 h-8 rounded-full ${type === 'success' ? 'bg-green-500/10' : 'bg-red-500/10'} flex items-center justify-center">
                    <i data-lucide="${type === 'success' ? 'check-circle' : 'alert-circle'}" class="w-4 h-4 ${type === 'success' ? 'text-green-500' : 'text-red-500'}"></i>
                </div>
                <span class="text-sm font-medium ${type === 'success' ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400'}">${message}</span>
            `;
            document.body.appendChild(toast);
            lucide.createIcons();
            setTimeout(() => toast.remove(), 4000);
        }

        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        }
        // Theme handled in <head> for FOUC prevention
        lucide.createIcons();
    </script>
</body>
</html>
