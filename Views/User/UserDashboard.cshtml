@model List<Portify.Models.Portfolio>
@{
    Layout = null;
    var templateNames = ViewBag.TemplateNames as Dictionary<int, string> ?? new Dictionary<int, string>();
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Portify</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <script>
        (function () {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif']
                    },
                    colors: {
                        brand: {
                            50: '#faf5ff',
                            100: '#f3e8ff',
                            300: '#d8b4fe',
                            500: '#a855f7',
                            600: '#9333ea',
                            900: '#581c87'
                        }
                    },
                    animation: {
                        'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    }
                }
            }
        }
    </script>

    <style>
        .noise-bg {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        }

        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .dark .glass {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .portfolio-card {
            transition: all 0.3s ease;
        }
        .portfolio-card:hover {
            transform: translateY(-4px);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #050505; }
        ::-webkit-scrollbar-thumb { background: #a855f7; border-radius: 10px; }

        /* Toast animations */
        @@keyframes toastIn {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes toastOut {
            from { opacity: 1; transform: translateY(0); }
            to { opacity: 0; transform: translateY(-20px); }
        }
    </style>
</head>

<body class="bg-white dark:bg-[#050505] text-gray-900 dark:text-white transition-colors duration-500 selection:bg-brand-500 selection:text-white min-h-screen flex flex-col">

    <!-- Background Ambient Effects -->
    <div class="fixed inset-0 z-0 pointer-events-none">
        <div class="absolute top-[20%] left-[20%] w-[40%] h-[40%] bg-brand-500/10 rounded-full blur-[120px] animate-pulse-slow"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-500/10 rounded-full blur-[120px] animate-pulse-slow" style="animation-delay: 1s;"></div>
        <div class="absolute inset-0 noise-bg opacity-30 dark:opacity-20"></div>
        <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20"></div>
    </div>

    <div class="relative z-10 flex-grow flex flex-col">
        @Html.Partial("~/Views/Shared/_UserNavbar.cshtml")

        <main class="flex-grow p-6 sm:p-10 max-w-7xl mx-auto w-full">

            <!-- Success Toast -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="toast fixed top-28 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-2xl shadow-2xl border border-green-500/20"
                     style="background:rgba(255,255,255,0.85);backdrop-filter:blur(12px);animation:toastIn 0.5s ease forwards, toastOut 0.4s ease 3s forwards;">
                    <div class="w-8 h-8 rounded-full bg-green-500/10 flex items-center justify-center">
                        <i data-lucide="check-circle" class="w-4 h-4 text-green-500"></i>
                    </div>
                    <span class="text-sm font-medium text-green-700 dark:text-green-400">@TempData["SuccessMessage"]</span>
                </div>
            }

            <!-- Page Header -->
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
                <div>
                    <h2 class="text-xs uppercase tracking-[0.4em] text-brand-500 font-bold mb-2">Welcome Back</h2>
                    <h1 class="text-4xl md:text-5xl font-serif italic text-gray-900 dark:text-white">
                        My <span class="not-italic text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-blue-600 dark:from-brand-400 dark:to-blue-400">Portfolios</span>
                    </h1>
                </div>

                <div class="flex items-center gap-4">
                    <div class="text-sm text-gray-500 dark:text-gray-400 font-sans">
                        Total: <span class="font-bold text-gray-900 dark:text-white">@Model.Count</span>
                    </div>
                    <a href="@Url.Action("Explore", "Dashboard")"
                       class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold uppercase tracking-wider
                              bg-gradient-to-r from-brand-600 to-brand-500 text-white
                              hover:from-brand-500 hover:to-brand-600 hover:shadow-[0_0_30px_rgba(168,85,247,0.3)]
                              hover:-translate-y-0.5
                              transition-all duration-300 shadow-lg">
                        <i data-lucide="plus" class="w-4 h-4"></i>
                        Create New
                    </a>
                </div>
            </div>

            @if (Model != null && Model.Count > 0)
            {
                <!-- Portfolios Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    @foreach (var portfolio in Model)
                    {
                        var tName = templateNames.ContainsKey(portfolio.TemplateId) ? templateNames[portfolio.TemplateId] : "Unknown";
                        <div class="portfolio-card glass rounded-2xl overflow-hidden shadow-lg group">
                            <!-- Card Header with gradient -->
                            <div class="h-32 relative overflow-hidden">
                                <div class="absolute inset-0 bg-gradient-to-br from-brand-600/80 to-blue-600/80 dark:from-brand-500/60 dark:to-blue-500/60"></div>
                                <div class="absolute inset-0 noise-bg opacity-40"></div>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="w-16 h-16 rounded-2xl bg-white/20 backdrop-blur-sm flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                                        <i data-lucide="file-text" class="w-8 h-8 text-white"></i>
                                    </div>
                                </div>
                                <!-- Portfolio ID Badge -->
                                <div class="absolute top-3 left-3">
                                    <span class="px-2 py-1 rounded-lg bg-white/20 backdrop-blur-sm text-white text-xs font-mono">#@portfolio.Id</span>
                                </div>
                            </div>

                            <!-- Card Body -->
                            <div class="p-5">
                                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1 truncate">
                                    @(string.IsNullOrEmpty(portfolio.Title) ? "Untitled Portfolio" : portfolio.Title)
                                </h3>

                                <div class="flex items-center gap-2 mb-3">
                                    <i data-lucide="layout-template" class="w-3.5 h-3.5 text-brand-500"></i>
                                    <span class="text-xs text-gray-500 dark:text-gray-400 font-medium">@tName</span>
                                </div>

                                <div class="flex items-center gap-2 mb-4">
                                    <i data-lucide="calendar" class="w-3.5 h-3.5 text-gray-400"></i>
                                    <span class="text-xs text-gray-400 dark:text-gray-500">@portfolio.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</span>
                                </div>

                                <!-- Actions -->
                                <div class="flex items-center gap-2 pt-3 border-t border-gray-100 dark:border-white/5">
                                    <a href="@Url.Action("Download", "Portfolio", new { id = portfolio.Id })"
                                       class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-xs font-bold uppercase tracking-wider
                                              bg-gradient-to-r from-brand-600 to-brand-500 text-white
                                              hover:from-brand-500 hover:to-brand-600 hover:shadow-[0_0_20px_rgba(168,85,247,0.25)]
                                              transition-all duration-200">
                                        <i data-lucide="download" class="w-3.5 h-3.5"></i>
                                        Download
                                    </a>
                                    <form action="@Url.Action("DeletePortfolio", "Dashboard")" method="post" class="inline">
                                        <input type="hidden" name="portfolioId" value="@portfolio.Id" />
                                        <button type="submit"
                                                onclick="return confirm('Are you sure you want to delete this portfolio?')"
                                                class="inline-flex items-center justify-center p-2.5 rounded-xl
                                                       border border-gray-200 dark:border-white/10
                                                       text-gray-400 hover:text-red-500 hover:border-red-500/30 dark:hover:border-red-500/30
                                                       transition-all duration-200"
                                                title="Delete portfolio">
                                            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Empty State -->
                <div class="glass rounded-3xl p-16 text-center shadow-2xl relative overflow-hidden">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-brand-500 to-transparent opacity-50"></div>

                    <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-brand-50 to-brand-100 dark:from-brand-900/20 dark:to-brand-800/20 flex items-center justify-center">
                        <i data-lucide="folder-open" class="w-10 h-10 text-brand-500 opacity-60"></i>
                    </div>

                    <h2 class="text-2xl font-serif italic text-gray-900 dark:text-white mb-3">No portfolios yet</h2>
                    <p class="text-gray-500 dark:text-gray-400 mb-8 max-w-md mx-auto">
                        You haven't created any portfolios yet. Explore our templates and build your first one!
                    </p>

                    <a href="@Url.Action("Explore", "Dashboard")"
                       class="inline-flex items-center gap-2 px-8 py-4 rounded-xl text-sm font-bold uppercase tracking-wider
                              bg-gradient-to-r from-brand-600 to-brand-500 text-white
                              hover:from-brand-500 hover:to-brand-600 hover:shadow-[0_0_30px_rgba(168,85,247,0.3)]
                              hover:-translate-y-0.5
                              transition-all duration-300 shadow-lg">
                        <i data-lucide="compass" class="w-4 h-4"></i>
                        Explore Templates
                    </a>
                </div>
            }

        </main>
    </div>

    <script>
        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        }

        // Theme handled in <head> for FOUC prevention
        lucide.createIcons();
    </script>
</body>
</html>