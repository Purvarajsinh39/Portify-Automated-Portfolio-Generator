## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Xx]64/
[Xx]86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015/2017/2019/2022 cache build results
.vs/
# Uncomment if you use a linting tool like StyleCop
#*.StyleCop

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml

# Build Complexity Plan results
_Chutzpah*

# Visual Studio 2015/2017/2019/2022 team project wheel file
*.wheel

# General
.DS_Store
.directory
.fuse_hidden*
.Trash-*
.nfs*

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, because it may contain MSBuild targets
!**/packages/build/
# Uncomment if using NuGet 2.x to ignore packages/ but keep repositories.config
# !**/packages/repositories.config

# Microsoft Azure Build Output
csx/
*.cscfg
*.csdef

# Windows Azure Emulator
ecf/
rcf/

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# Built-in Web One-Click Publish
*.Publish.xml
*.pubxml
*.publishproj

# SQL Server files
*.mdf
*.ldf
*.ndf
*.log
*.tmp
*.bak

# Portify specific ignored files (DB dumps/temp)
# portify.sql
# portify_utf8.sql

# Others
desktop.ini
